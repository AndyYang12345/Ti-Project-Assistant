def write_launch_json(project_dir: str, ctx: dict, dry_run: bool = False):
    """Generate .vscode/launch.json."""
    debugger = ctx["debugger"]
    if debugger == "none":
        info("  - Skip launch.json (debugger=none)")
        return

    dbg_cfg = DEBUGGER_CONFIG[debugger]
    config_files = ",\n                ".join(
        f'"{f}"' for f in dbg_cfg["configFiles"]
    )
    debugger_label = "CMSIS-DAP" if debugger == "cmsis-dap" else "XDS110"

    # Build OpenOCD paths, handling Windows variants
    openocd_dir = ctx["openocd_dir"]
    if IS_WIN and openocd_dir.endswith(".exe"):
        # openocd_dir already points to openocd.exe (from CCS fallback)
        openocd_bin = openocd_dir
        openocd_scripts = os.path.join(os.path.dirname(openocd_dir), "..", "scripts")
    else:
        openocd_exe = "openocd.exe" if IS_WIN else "openocd"
        openocd_bin = os.path.join(openocd_dir, "bin", openocd_exe)
        openocd_scripts = os.path.join(openocd_dir, "share", "openocd", "scripts")

    # Normalize: JSON-friendly forward slashes
    openocd_bin = openocd_bin.replace("\\", "/")
    openocd_scripts = openocd_scripts.replace("\\", "/")
    gdb_dir = ctx["gdb_dir"].replace("\\", "/")

    content = LAUNCH_JSON_TEMPLATE.format(
        device_name=ctx["device_name"],
        debugger_label=debugger_label,
        project_name=ctx["project_name"],
        config_files=config_files,
        openocd_scripts=openocd_scripts,
        openocd_bin=openocd_bin,
        gdb_dir=gdb_dir,
    )

    dest = os.path.join(project_dir, ".vscode", "launch.json")
    if dry_run:
        info(f"[dry-run] Write .vscode/launch.json")
        return
    with open(dest, "w") as f:
        f.write(content)
    info("  ✓ .vscode/launch.json")



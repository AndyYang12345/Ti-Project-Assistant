MAIN_C_TEMPLATE = """\
#include "ti_msp_dl_config.h"

/**
 * @brief  Simple delay function (CPU cycle-based)
 * @param  ms  delay in milliseconds
 * @note   CPUCLK_FREQ = {cpu_freq_hz} Hz
 */
static void delay_ms(uint32_t ms)
